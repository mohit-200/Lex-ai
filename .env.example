# Ollama — local LLM, no API key needed
LLM_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=llama3.2:3b
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=legaldoc

# Redis
REDIS_URL=redis://redis:6379/0

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://legaldoc:legaldoc@postgres:5432/legaldoc

# App
APP_ENV=development
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=6
CONFIDENCE_THRESHOLD=0.72
